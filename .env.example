# ─── App ───────────────────────────────────────────────────────────
APP_NAME="CRM Agency"
DEBUG=false
SECRET_KEY=replace_with_secure_random_secret

# ─── Database ──────────────────────────────────────────────────────
POSTGRES_DB=crm_agency
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=strong_password_here
DATABASE_URL=postgresql+asyncpg://crm_user:strong_password_here@postgres:5432/crm_agency

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ───────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ─── Telegram UserBot (MTProto) ────────────────────────────────────
# Получить на https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Номер телефона аккаунта-юзербота (формат: +79001234567)
TELEGRAM_PHONE=+79001234567
# Session string — генерируется при первом запуске (python -m bot.gen_session)
TELEGRAM_SESSION=

# ─── Bot Service ───────────────────────────────────────────────────
API_URL=http://backend:8000

# ─── Frontend (замени на IP сервера или домен) ─────────────────────
# Пример: NEXT_PUBLIC_API_URL=http://1.2.3.4
# Пример: NEXT_PUBLIC_API_URL=https://crm.example.com
NEXT_PUBLIC_API_URL=

# ─── WhatsApp (Green API) ──────────────────────────────────────────
GREEN_API_INSTANCE=
GREEN_API_TOKEN=

# ─── MAX (Mail.ru) ─────────────────────────────────────────────────
MAX_BOT_TOKEN=

# ─── Email (SMTP) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── Google Sheets Sync ────────────────────────────────────────────
# ID таблицы из URL: https://docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=1f1Uldq5ncCNRGmrRjtyFf88-CgV2_DzVVmh_bf-Z73U
# Путь к JSON-файлу сервисного аккаунта Google (внутри контейнера)
GOOGLE_CREDENTIALS_FILE=/app/google_credentials.json
# Интервал синхронизации в секундах (по умолчанию 120 = 2 минуты)
SHEETS_SYNC_INTERVAL_SECONDS=120
